		{
			"name": "TC-API-01 Search and Filter Job Ads (Multiple conditions)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Response contains data array\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.data.data.data).to.be.an(\"array\");",
							"    if (jsonData.data.data.data.length > 0) {",
							"        pm.collectionVariables.set(\"job_id\", jsonData.data.data.data[0].id);",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/job-ad/outside/filter?keyword=Java",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"job-ad",
						"outside",
						"filter"
					],
					"query": [
						{
							"key": "keyword",
							"value": "Java"
						}
					]
				}
			}
		},
