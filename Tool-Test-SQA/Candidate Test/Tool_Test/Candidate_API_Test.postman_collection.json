			"name": "TC-API-00 Login to get Token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set(\"jwt_token\", jsonData.data.token);",
							"pm.test(\"Login successful\", function () {",
							"    pm.response.to.have.status(200);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"username\": \"sqapananh2026\",\n  \"password\": \"Test@12345\"\n}"
				},
				"url": {
					"raw": "http://localhost:8888/api/v1/user/auth/login",
					"protocol": "http",
					"host": [
						"localhost"
					],
